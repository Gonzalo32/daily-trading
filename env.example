# ==================================================
# CONFIGURACIÓN DEL BOT DE TRADING
# ==================================================
# Copia este archivo como .env y configura tus valores

# ==================================================
# MODO DE OPERACIÓN
# ==================================================
TRADING_MODE=PAPER
# Opciones: PAPER (simulado) o LIVE (real - ⚠️ PELIGRO)

MARKET=CRYPTO
# Opciones: CRYPTO o STOCK

SYMBOL=BTC/USDT
# Para crypto: BTC/USDT, ETH/USDT, etc.
# Para stocks: AAPL, TSLA, etc.

TIMEFRAME=5m
# Timeframe de análisis: 1m, 5m, 15m, 1h, etc.

# ==================================================
# CAPITAL Y RIESGO
# ==================================================
INITIAL_CAPITAL=10000
# Capital inicial en USD

RISK_PER_TRADE=0.02
# Riesgo por trade (2% = 0.02)

MAX_DAILY_LOSS=0.03
# Pérdida máxima diaria (3% = 0.03)

MAX_DAILY_GAIN=0.05
# Ganancia máxima diaria (5% = 0.05)

MAX_DAILY_TRADES=20
# Máximo de trades por día

MAX_POSITIONS=2
# Posiciones abiertas simultáneas

STOP_LOSS_PCT=0.03
# Stop loss porcentual (3% = 0.03)

TAKE_PROFIT_RATIO=1.0
# Ratio take profit (1:1)

# ==================================================
# BINANCE (CRYPTO) - TESTNET
# ==================================================
BINANCE_TESTNET=true
# true = testnet (simulado), false = live

BINANCE_API_KEY=
# Deja vacío para modo PAPER
# Para testnet: obtén keys en https://testnet.binance.vision/

BINANCE_SECRET_KEY=
# Deja vacío para modo PAPER

# ==================================================
# ALPACA (STOCKS) - PAPER TRADING
# ==================================================
ALPACA_API_KEY=
# Obtén keys gratuitas en https://alpaca.markets/

ALPACA_SECRET_KEY=
# Paper trading es gratis

ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Paper trading URL

# ==================================================
# MACHINE LEARNING
# ==================================================
# --- ML Shadow Logging (ml_decisions.db) ---
ML_ENABLED=true
ML_MODE=shadow
ML_THRESHOLD=0.55
MODEL_VERSION=shadow_stub_v1
FEATURE_VERSION=v1
ML_DECISIONS_DB_PATH=data/ml_decisions.db
# SQLite donde se guardan decisiones ML

# --- Legacy / Real Models (.pkl) ---
ENABLE_LEGACY_ML_FILTER=false
ML_MODEL_PATH=models/
# ML_MODEL_PATH puede ser carpeta o archivo .pkl
# Config lo normaliza a ML_LEGACY_MODEL_FILE (derivado)
ML_V2_MODEL_FILE=models/ml_v2_model.pkl
ML_MIN_PROBABILITY=0.55

# --- Live Gating (bloqueo real por ML) ---
ML_GATING_LIVE_ENABLED=false
ML_GATING_MODE=legacy
# legacy | v2 | both
ML_GATING_STRATEGY=block
# block | percentile_block
# Si ML_GATING_LIVE_ENABLED=true en LIVE, el modelo requerido debe existir.

# --- ML Audit / Export ---
ML_AUDIT_EVERY_N_DECISIONS=200

# --- Dataset / Training CSV ---
ENABLE_TRAINING_SCHEMA_MIGRATION=false
ENABLE_AUTO_TRAIN=false

# ==================================================
# LOGGING Y MONITOREO
# ==================================================
LOG_LEVEL=INFO
# DEBUG, INFO, WARNING, ERROR

LOG_FILE=logs/trading_bot.log
# Ruta del archivo de logs

ENABLE_DASHBOARD=true
# Dashboard web en http://localhost:8000

ENABLE_NOTIFICATIONS=false
# Notificaciones (requiere configuración adicional)

# ==================================================
# ESTRATEGIA
# ==================================================
FAST_MA_PERIOD=9
# Período EMA rápida

SLOW_MA_PERIOD=21
# Período EMA lenta

RSI_PERIOD=14
# Período RSI

RSI_OVERBOUGHT=70
# RSI sobrecompra

RSI_OVERSOLD=30
# RSI sobreventa

# ==================================================
# DEBUG (SOLO PARA DESARROLLO)
# ==================================================
ENABLE_DEBUG_STRATEGY=false
# true = desactiva filtros (PELIGROSO)

# ==================================================
# NOTAS IMPORTANTES
# ==================================================
# 1. NO subas el archivo .env a git (está en .gitignore)
# 2. En modo PAPER no necesitas API keys
# 3. Para LIVE, usa primero testnet durante semanas
# 4. NUNCA uses LIVE sin probar extensivamente en PAPER
